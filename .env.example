# ─────────────────────────────────────────────
# Database (used by server in Phase 2)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://poker:poker_dev_password@localhost:5432/poker_dev

# ─────────────────────────────────────────────
# Redis (used by server in Phase 2)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# Server (used in Phase 2)
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─────────────────────────────────────────────
# Auth — Auth.js with Google OAuth (Phase 2)
# ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=change_me_in_production

# Auth.js will compute callback URLs from this in dev
AUTH_URL=http://localhost:3000

# Get from https://console.cloud.google.com/apis/credentials
# Phase 2 will document the exact OAuth consent screen + credentials setup
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Game-server JWT (issued by Next.js, verified by Fastify)
# Same secret as AUTH_SECRET for now; can be split later if needed
# ─────────────────────────────────────────────
GAME_JWT_SECRET=change_me_in_production
