{
  "name": "@poker-app/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@poker-app/engine": "workspace:*",
    "@poker-app/shared": "workspace:*"
  },
  "devDependencies": {
    "@poker-app/eslint-config": "workspace:*",
    "@poker-app/tsconfig": "workspace:*",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
